# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=uncommon-dodo-93 # team: arnold-gamboa, project: youpastor

VITE_CONVEX_URL=https://uncommon-dodo-93.convex.cloud

VITE_CONVEX_SITE_URL=https://uncommon-dodo-93.convex.site

# OpenRouter
VITE_AI_PROVIDER=openrouter
# Do not expose OpenRouter keys in the production renderer bundle.
VITE_AI_API_KEY=

# AI Models by role
# VITE_AI_MODEL_ORCHESTRATOR=minimax/minimax-m2.5:free
# VITE_AI_MODEL_GENERATOR=minimax/minimax-m2.5:free
# VITE_AI_MODEL_RESEARCHER=nvidia/nemotron-3-super-120b-a12b:free

VITE_AI_MODEL_ORCHESTRATOR=minimax/gemini-3.1-flash-lite
VITE_AI_MODEL_GENERATOR=mminimax/gemini-3.1-flash-lite
VITE_AI_MODEL_RESEARCHER=perplexity/sonar
# Keep disabled until Convex Auth Google OAuth is fully resolved.

VITE_ENABLE_GOOGLE_AUTH=true