{
  "name": "youpastor",
  "private": true,
  "version": "0.1.0",
  "productName": "YouPastor",
  "description": "Desktop-first AI Workspace for pastors",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build && electron-builder",
    "preview": "vite preview",
    "convex:dev": "convex dev",
    "seed:skills": "node scripts/seed-skills.mjs",
    "seed:load": "node scripts/seed-skills.mjs && npx convex run skills/seed:seedAll --json-file scripts/seed-data.json"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@tiptap/extension-highlight": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@tiptap/vue-3": "^3.23.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.39.1",
    "dexie": "^4.4.2",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.3",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@convex-dev/auth": "^0.0.92",
    "@tailwindcss/typography": "^0.5.19",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.5.0",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.26"
  },
  "main": "dist-electron/main.js"
}
